from analyze_video import analyze_videos

def extract_frames_from_videos(directory, train_split, val_split, duration_seconds, frame_interval, subfolder_name):
    """
    Extracts frames from videos and splits them into Train and Validation folders.

    Args:
        directory (str): The path to the directory containing video files.
        train_split (int): The number of videos to put in the Train folder.
        val_split (int): The number of videos to put in the Validation folder.
        duration_seconds (int): The duration in seconds from the start of the video to extract frames from.
        frame_interval (int): The time interval in seconds between extracted frames.
        subfolder_name (str): The label/subfolder name (e.g., 'deepfake' or 'original_vids').
    """
    video_files = []
    for root, _, files in os.walk(directory):
        for file in files:
            if file.endswith(".mp4"):
                video_files.append(os.path.join(root, file))

    if not video_files:
        print(f"No .mp4 files found in the directory: {directory}")
        return

    train_videos = video_files[:train_split]
    val_videos = video_files[train_split:train_split + val_split]

    print(f"Found {len(video_files)} videos.")
    print(f"Allocating {len(train_videos)} to Train and {len(val_videos)} to Validation.")

    total_frames_extracted = 0

    def process_split(video_list, split_name):
        output_folder = os.path.join(split_name, subfolder_name)
        if not os.path.exists(output_folder):
            os.makedirs(output_folder)
            print(f"Created directory: {output_folder}")

        split_frames_extracted = 0
        vid_num = 0
        print(f"\n--- Processing {split_name} Split ---")
        
        for video_path in video_list:
            try:
                cap = cv2.VideoCapture(video_path)
                if not cap.isOpened():
                    print(f"Error opening video file: {video_path}")
                    continue

                fps = cap.get(cv2.CAP_PROP_FPS)
                if fps == 0:
                    print(f"Could not get FPS for {video_path}. Skipping.")
                    cap.release()
                    continue
                
                video_filename = os.path.splitext(os.path.basename(video_path))[0]
                vid_num += 1
                
                # Print progress update
                if vid_num % 50 == 0 or vid_num == len(video_list):
                    print(f"Processed {vid_num}/{len(video_list)} videos in {split_name}...")

                # Loop through the duration, stepping by the frame interval
                for sec in range(0, duration_seconds, frame_interval):
                    frame_id = int(fps * sec)
                    cap.set(cv2.CAP_PROP_POS_FRAMES, frame_id)
                    
                    ret, frame = cap.read()
                    if ret:
                        # Save the frame as a JPG file with a more precise name
                        output_filename = f"{video_filename}_sec{sec}.jpg"
                        output_path = os.path.join(output_folder, output_filename)
                        cv2.imwrite(output_path, frame, [cv2.IMWRITE_JPEG_QUALITY, 95])
                        split_frames_extracted += 1
                    else:
                        # Commenting out missing frames note to reduce terminal spam
                        # print(f"  - Could not read frame at {sec}s for {video_filename}.mp4")
                        pass

                cap.release()
            except Exception as e:
                print(f"Could not process {video_path}: {e}")
                
        print(f"{split_name} extraction complete. Frames saved: {split_frames_extracted}")
        return split_frames_extracted

    if train_videos:
        total_frames_extracted += process_split(train_videos, "Train")
    if val_videos:
        total_frames_extracted += process_split(val_videos, "Validation")

    print(f"\nTotal extraction complete. Grand total frames saved: {total_frames_extracted}")



